{
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "limepages.co.za" }],
      "destination": "https://www.limepages.co.za/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/lehumo/cron/contribution-reminder?kind=first",
      "schedule": "0 7 15 * *"
    },
    {
      "path": "/api/lehumo/cron/contribution-reminder?kind=final",
      "schedule": "0 7 25 * *"
    },
    {
      "path": "/api/lehumo/cron/orphan-scan",
      "schedule": "0 5 * * *"
    }
  ]
}
